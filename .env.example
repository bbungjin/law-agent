# LLM Provider 선택: "anthropic" | "openai"
LLM_PROVIDER=openai

# Anthropic / OpenAI API 키
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ──────────────────────────────────────────────────────────────────
# 국가법령정보 공동활용 Open API (open.law.go.kr)
#
# 발급 방법:
#   1. https://open.law.go.kr 회원가입
#   2. 로그인 후 [마이페이지] → [API 활용신청] (승인까지 1~2일)
#   3. 승인 후 가입한 이메일 주소를 아래에 입력 (이메일이 곧 인증키)
#
# 사용 가능 API:
#   - 법령 검색:  lawSearch.do?target=law
#   - 법령 본문:  lawService.do?target=law&MST=...
#   - 판례 검색:  lawSearch.do?target=prec
#   - 판례 본문:  lawService.do?target=prec&MST=...
# ──────────────────────────────────────────────────────────────────
LAW_OC=your_email@example.com

# 임베딩 모델 (sentence-transformers, 한국어 지원 모델)
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask
